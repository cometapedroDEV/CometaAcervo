
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the application, storing profile and affiliate info.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "isAffiliate": { "type": "boolean", "description": "Whether the user is an active affiliate." },
        "affiliateId": { "type": "string", "description": "Unique ID for referral links." },
        "walletBalance": { "type": "number", "description": "Current earned commission balance." }
      },
      "required": ["id", "email", "registrationDate"]
    },
    "ExternalPlatform": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExternalPlatform",
      "type": "object",
      "description": "Represents an external course hosting platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "baseUrl": { "type": "string", "format": "uri" },
        "loginUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents a course available for purchase.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "externalPlatformId": { "type": "string" },
        "externalCourseIdentificationStrings": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "description", "price", "externalPlatformId", "externalCourseIdentificationStrings"]
    },
    "ExternalAccountCredential": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExternalAccountCredential",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "externalPlatformId": { "type": "string" },
        "accessIdentifier": { "type": "string" },
        "providedCourseTitles": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "externalPlatformId", "accessIdentifier", "providedCourseTitles"]
    },
    "CourseRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CourseRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseName": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["courseName", "requestedAt"]
    },
    "Purchase": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "courseTitle": { "type": "string" },
        "purchasedAt": { "type": "string", "format": "date-time" },
        "affiliateId": { "type": "string", "description": "ID of the affiliate who referred this sale." },
        "commissionAmount": { "type": "number", "description": "Commission earned by the affiliate." }
      },
      "required": ["userId", "courseId", "courseTitle", "purchasedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/user_profiles/{userProfileId}", "definition": { "entityName": "UserProfile", "description": "Stores user profiles and wallet info." } },
      { "path": "/external_platforms/{platformId}", "definition": { "entityName": "ExternalPlatform" } },
      { "path": "/courses/{courseId}", "definition": { "entityName": "Course" } },
      { "path": "/external_account_credentials/{credentialId}", "definition": { "entityName": "ExternalAccountCredential" } },
      { "path": "/course_requests/{requestId}", "definition": { "entityName": "CourseRequest" } },
      { "path": "/purchases/{purchaseId}", "definition": { "entityName": "Purchase" } }
    ]
  }
}
