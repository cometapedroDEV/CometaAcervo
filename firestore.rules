rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CURSO DIGITAL SECURITY RULES - PROTOTYPING MODE
     * 
     * philosophy:
     * 1. Strict Authorization: Access is strictly controlled based on user identity (Firebase Auth) 
     *    and roles defined in the database.
     * 2. Schema Flexibility: While authorization is strict, the structure of the data itself 
     *    is flexible to allow for rapid development and iteration.
     * 3. Admin-Centric Management: External platforms, course catalogs, and account credentials 
     *    (logins for external platforms) are managed exclusively by administrators.
     * 4. User-Ownership: Users have full access to their own profiles and purchase history 
     *    via path-based security and denormalized ownership fields.
     * 5. Public Discovery: The course catalog and platform definitions are publicly readable 
     *    to allow unauthenticated browsing and search.
     * 
     * DATA HIERARCHY:
     * - /user_profiles/{uid}: User-specific profile data.
     * - /roles_admin/{uid}: Marker documents identifying administrative users.
     * - /external_platforms/{id}: Definitions of platforms like Kwify, Ticto, etc.
     * - /courses/{id}: The product catalog.
     * - /external_account_credentials/{id}: Admin-only store for external login data.
     * - /users/{uid}/purchases/{id}: User-specific records of course acquisitions.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the request is coming from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has an administrator role.
     * Relies on the existence of a document in the 'roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Checks if the provided UID matches the authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Verifies ownership and ensures the document exists for state-changing operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description User profile management. Owners can manage their data; Admins can view/manage all.
     * @path /user_profiles/{userProfileId}
     * @allow get (authenticated owner), update (owner ensuring ID immutability)
     * @deny create (if UID doesn't match path), delete (non-admins)
     * @principle Path-based ownership and relational integrity.
     */
    match /user_profiles/{userProfileId} {
      allow get: if isOwner(userProfileId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if (isExistingOwner(userProfileId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Administrative roles. Used for DBAC (Database-Based Access Control).
     * @path /roles_admin/{adminId}
     * @allow get (self-check), list/write (existing admins only)
     * @deny write (non-admins)
     * @principle Secure role-based access control.
     */
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description External platform definitions (e.g., Kwify).
     * @path /external_platforms/{platformId}
     * @allow read (public), write (admin only)
     * @deny write (standard users)
     * @principle Public read for discovery with admin-only data management.
     */
    match /external_platforms/{platformId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Course catalog.
     * @path /courses/{courseId}
     * @allow read (public), write (admin only)
     * @deny write (standard users)
     * @principle Public read for catalog browsing; strict admin control over products.
     */
    match /courses/{courseId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Sensitive external credentials (logins/passwords).
     * @path /external_account_credentials/{credentialId}
     * @allow all (admin only)
     * @deny all (any non-admin user)
     * @principle Strict administrative isolation for sensitive system data.
     */
    match /external_account_credentials/{credentialId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description User purchase records. Nested under users for path-based security.
     * @path /users/{userProfileId}/purchases/{purchaseId}
     * @allow get/list (owner or admin), create (owner with ID validation)
     * @deny update/delete (to maintain immutable audit trail of purchases)
     * @principle Path-based ownership for private records; immutable transaction history.
     */
    match /users/{userProfileId}/purchases/{purchaseId} {
      allow get, list: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId) && request.resource.data.userProfileId == userProfileId;
      allow update, delete: if isAdmin(); // Only admins can correct or remove transaction records.
    }
  }
}